# ============================================================
#  MCP Filesystem Ultra - .gitignore
# ============================================================

# ------------------------------------------------------------
# Go Binaries & Build Artifacts
# ------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Intentionally built release binaries (we commit only source)
filesystem-ultra-v4*
mcp-proxy*
filesystem-ultra-v4-dashboard*

# Legacy / stray binaries
mcp-filesystem-ultra
mcp-filesystem-ultra.exe
filesystem-ultra.exe
filesystem-ultra.exe___

# ------------------------------------------------------------
# Go toolchain & modules
# ------------------------------------------------------------
go.work
go.work.sum
vendor/

# Coverage and test binaries
*.out
*.test
*.coverage
test_output/

# ------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS generated files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db

# ------------------------------------------------------------
# Logs, temp & cache
# ------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.backup

cache/data/
cache/metadata/
.cache/

# ------------------------------------------------------------
# Benchmark & profiling
# ------------------------------------------------------------
bench/results/
*.bench

# ------------------------------------------------------------
# Build output directories
# ------------------------------------------------------------
build/
dist/
bin/

# ------------------------------------------------------------
# Environment & secrets
# ------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ------------------------------------------------------------
# Project-specific artifacts
# ------------------------------------------------------------
# Hooks (compiled / local overrides)
hooks.json
hooks.local.json

# Local hooks test file (the example lives in examples/hooks-test.json)
hooks-test.json

# Test data & temporary test artifacts
test_files/
filesdelete/
Revisar_implantar_o_borrar/
temp_test/
test_*.txt
before.txt

# ------------------------------------------------------------
# Claude / AI agent artifacts (keep only the custom skill)
# ------------------------------------------------------------
.agent/
.agents/
.claude/settings.json
.claude/settings.local.json
.claude/skills/*
!.claude/skills/filesystem-ultra-tools/
.claude/commands/
.claude/worktrees/
.mcp.json

# ------------------------------------------------------------
# Legacy / junk that should never be committed
# ------------------------------------------------------------
morralla/
borrar/
scratch/
private/

# Temporary planning / internal docs (moved to morralla historically)
BUILD_SUCCESS.md
IMPLEMENTATION_VERIFICATION.md
PIPELINE_IMPLEMENTATION_SUMMARY.md
PipelinePlan.md
COMPETITIVE_ANALYSIS.md
ROADMAP.md

# ------------------------------------------------------------
# docs-website (has its own git history / is a separate concern)
# ------------------------------------------------------------
docs-website/
docs-website/.claude/

# ------------------------------------------------------------
# Note: No legacy media files are kept at project root anymore.
# All Scopweb logos used in documentation live inside docs-website/src/assets/
# (scopweb.png and scopweb3.png)
